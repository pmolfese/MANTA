{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manta.local/schemas/change-log-1.0.0.json",
  "title": "MANTA Immutable Bundle Change Log 1.0.0",
  "type": "object",
  "required": ["$schema", "schemaVersion", "bundleID", "parentBundleID", "createdAt", "producer", "changes"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "bundleID": { "type": "string", "format": "uuid" },
    "parentBundleID": { "type": "string", "format": "uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "producer": {
      "type": "object",
      "required": ["application", "version", "build", "platform", "operatingSystemVersion", "deviceModel"],
      "properties": {
        "application": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "build": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "operatingSystemVersion": { "type": "string", "minLength": 1 },
        "deviceModel": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "changedAt", "category", "summary", "targets"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "changedAt": { "type": "string", "format": "date-time" },
          "category": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "targets": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
